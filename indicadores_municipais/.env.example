# === Configurações de Ambiente ===
# Copie este arquivo para .env e ajuste conforme necessário

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Caminho da planilha de entrada (opcional — pode ser passado via CLI)
# INPUT_FILE=caminho/para/planilha.xlsx

# Habilitar/desabilitar cache de dados
# CACHE_ENABLED=true

# Modo headless do Playwright (true = sem interface gráfica)
# HEADLESS_BROWSER=true
